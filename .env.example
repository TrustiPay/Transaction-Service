# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustipay_transactions

# Redis (shared with gateway)
REDIS_URL=redis://localhost:6379

# Fraud Detection Service (internal network call)
FRAUD_DETECTION_URL=http://localhost:8000

# Feature Flags
OFFLINE_PAYMENTS_ENABLED=false
OFFLINE_SETTLEMENT_MODE=shadow
OFFLINE_MAX_WALLET_MINOR=500000
OFFLINE_MAX_TXN_MINOR=100000
OFFLINE_TOKEN_EXPIRY_DAYS=7
OFFLINE_MAX_UNSYNCED_TXNS=20
OFFLINE_REQUIRED_SYNC_HOURS=48

# Server Signing Key (for offline token signing — never hardcode key material)
SERVER_SIGNING_KEY_ID=server-key-2026-05
SERVER_SIGNING_KEY_ALGORITHM=ECDSA_P256
SERVER_SIGNING_PRIVATE_KEY_PATH=/run/secrets/server_signing_key

# Internal service auth (used by X-Internal-Service header guard)
INTERNAL_SERVICE_SECRET=replace-me-in-production
