datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model OnlineTransaction {
  id              String    @id @default(cuid())
  senderUserId    String
  receiverUserId  String
  senderDeviceId  String
  amountMinor     BigInt
  currency        String    @default("LKR")
  // PENDING | PROCESSING | SETTLED | FAILED | REJECTED_FRAUD_BLOCK | FRAUD_REVIEW
  status          String
  requestHash     String
  fraudCaseId     String?
  fraudDecision   String?
  idempotencyKey  String    @unique
  createdAt       DateTime  @default(now())
  settledAt       DateTime?
  rejectionReason String?

  @@index([senderUserId])
  @@index([status])
  @@map("online_transactions")
}

model DeviceKey {
  publicKeyId String    @id
  userId      String
  deviceId    String
  publicKey   String
  algorithm   String
  // PENDING | ACTIVE | SUSPENDED | REVOKED | LOST | REPLACED
  status      String
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([deviceId])
  @@index([status])
  @@map("device_keys")
}

model ServerSigningKey {
  serverKeyId String    @id
  algorithm   String
  publicKey   String
  // PENDING | ACTIVE | RETIRED | REVOKED
  status      String
  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  retiredAt   DateTime?
  expiresAt   DateTime?

  @@map("server_signing_keys")
}

model OfflineToken {
  tokenId               String    @id
  ownerUserId           String
  ownerDeviceId         String
  amountMinor           BigInt
  currency              String
  // ISSUED | SPENT | EXPIRED | REVOKED | DISPUTED
  status                String
  issuedAt              DateTime  @default(now())
  expiresAt             DateTime
  serverKeyId           String
  tokenPayloadCanonical Bytes
  serverSignature       String
  spentTransactionId    String?
  spentAt               DateTime?

  @@index([ownerUserId, ownerDeviceId])
  @@index([status])
  @@index([expiresAt])
  @@map("offline_tokens")
}

model OfflineTransaction {
  transactionId    String    @id
  requestId        String?
  senderUserId     String?
  receiverUserId   String?
  senderDeviceId   String?
  receiverDeviceId String?
  amountMinor      BigInt
  currency         String
  // SETTLED | REJECTED_INVALID_SIGNATURE | REJECTED_TOKEN_EXPIRED | REJECTED_TOKEN_REVOKED
  // REJECTED_DOUBLE_SPEND | REJECTED_DEVICE_REVOKED | REJECTED_AMOUNT_MISMATCH
  // REJECTED_CURRENCY_MISMATCH | REJECTED_PROTOCOL_VERSION | REJECTED_FRAUD_BLOCK | FRAUD_REVIEW | DISPUTED
  status           String
  requestPayload   Bytes?
  offerPayload     Bytes
  receiptPayload   Bytes
  transportType    String?
  createdAtDevice  DateTime?
  receivedAtServer DateTime  @default(now())
  settledAt        DateTime?
  rejectionReason  String?

  @@index([senderUserId])
  @@index([receiverUserId])
  @@index([status])
  @@map("offline_transactions")
}

model IdempotencyKey {
  idempotencyKey String   @id
  userId         String?
  endpoint       String
  requestHash    String
  responseBody   Json?
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
  @@map("idempotency_keys")
}

model OfflineAuditEvent {
  auditEventId  String   @id @default(cuid())
  eventType     String
  userId        String?
  deviceId      String?
  transactionId String?
  tokenId       String?
  payload       Json?
  createdAt     DateTime @default(now())

  @@map("offline_audit_events")
}
